#!/bin/bash

bold=$(tput bold) dim=$(tput dim) norm=$(tput sgr0)

case "$1" in
    --help|-h) printf "
Usage: ${dim}[ARCH=…] [DIST=…]${norm} ${bold}$(basename "$0")${norm} [--minimal|-m]

";;

    *)  case "$1" in
            --minimal|-m) phase="chroot-setup";;
            *) phase="starting-build";;
        esac
        build-binary --nolog --${phase}-commands="%SBUILD_SHELL" --${phase}-commands="false" hello
    ;;
esac
