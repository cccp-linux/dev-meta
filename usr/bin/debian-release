#!/bin/bash

git-log-oneline() { git log --oneline --no-decorate "$@"; }

dch-add-from-stdin()
{
    while read sha msg; do
        local DEBFULLNAME=$(git show -s --format="%an" $sha)
        dch -a "$msg"
    done
    unset DEBFULLNAME
}

dch-bump-version()
{
    dch -Ui "Check version above and delete this line"
    dch -e
    dpkg-parsechangelog -S Source >/dev/null 2>&1
}

dch-release()
{
    dch -rD unstable
    dpkg-parsechangelog -S Source >/dev/null 2>&1
}

dch-commit()
{
    local ver=$(dpkg-parsechangelog -S Version)
    git add debian/changelog
    git commit -m "Update changelog for $ver release"
}

git-debian-tag()
{
    local ver=$(dpkg-parsechangelog -S Version)
    local tag=debian/$(echo $ver | tr ':~' '%_')
    git tag $tag
}

debian-release()
{
    local ver=$(dpkg-parsechangelog -S Version)
    local distro=$(dpkg-parsechangelog -S Distribution)

    if [[ "$distro" == "UNRELEASED" ]]; then
        ver=$(dpkg-parsechangelog -u $ver -S Version)
    else
        dch-bump-version || return
    fi

    local tag=debian/$(echo $ver | tr ':~' '%_')
    if [[ -n $(git tag -l $tag) ]]; then
        git-log-oneline $tag.. | dch-add-from-stdin
    else
        git-log-oneline | dch-add-from-stdin
    fi
    dch-release || return
    dch-commit
    git-debian-tag
}

bold=$(tput bold) dim=$(tput dim) norm=$(tput sgr0)

# detect if this script was sourced
[[ "$0" == *bash ]] || case "$1" in
    --help|-h) printf "
Usage: ${dim}[source]${norm} ${bold}$(basename "$0")${norm}

When prefixed with ${dim}source${norm}, ${bold}$(basename "$0")${norm} will export the following functions
and let you do your thing:

* dch-add-from-stdin
* dch-bump-version
* dch-commit
* dch-release
* debian-release
* git-debian-tag
* git-log-oneline

Otherwise, it will run the following:

1. (optional) dch-bump-version
2. git-log-oneline <prev>.. | dch-add-from-stdin
3. dch-release
4. dch-commit
5. git-debian-tag\n\n";;

    *) debian-release;;
esac
