#!/bin/bash

bold=$(tput bold) dim=$(tput dim) norm=$(tput sgr0)

case "$1" in
    --help|-h) printf "
Usage: ${bold}$(basename "$0")${norm} [-R|--recursive] ${dim}[package_0.42.orig.tar.{bz2,gz,xz}]${norm}

";;

    *)  case "$1" in
            -R|--recurse) recurse=--recurse-submodules; shift;;
        esac

        path="$1"
        if [[ ! "$path" ]]; then
            if [[ -f debian/changelog ]]; then
                n=$(dpkg-parsechangelog -S Source)
                v=$(dpkg-parsechangelog -S Version | sed "s/^.\+://; s/-[^-]\+$//")
            else
                n=$(basename "`pwd`")
                v=$(git tag --sort=-creatordate --merge | head -n1 | sed "s/^v//")
            fi

            path=../${n}_${v}.orig.tar.gz
            echo "Creating source package `tput bold`$path`tput sgr0`"
        fi

        git ls-files -z $recurse :^debian | tar -capf "$path" --null -T-
    ;;
esac
