#!/bin/bash

b=$(tput bold) n=$(tput sgr0)
sbuild=$(basename "$0")

case "$1" in
    --help|-h)
        echo "
Usage: ${b}${sbuild}${n} [-m|--minimal] -d|--dist=<distro> [options...]

See ${b}man sbuild${n} for options.
"
        exit 0;;

    --minimal|-m) phase="chroot-setup"; shift;;

    *) phase="starting-build";;
esac

exec ${sbuild%-shell} --nolog --${phase}-commands="%SBUILD_SHELL" --${phase}-commands="false" hello "$@"
